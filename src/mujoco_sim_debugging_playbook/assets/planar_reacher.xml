<mujoco model="planar_reacher">
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.002" gravity="0 0 0" integrator="RK4"/>

  <default>
    <joint damping="1.8" armature="0.03" limited="true"/>
    <geom type="capsule" size="0.018" rgba="0.18 0.44 0.85 1"/>
    <site size="0.02"/>
    <motor ctrllimited="true" ctrlrange="-6 6"/>
  </default>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.8" pos="0 0 1"/>
    <geom name="floor" type="plane" size="1 1 0.1" rgba="0.95 0.95 0.95 1"/>

    <body name="base" pos="0 0 0">
      <site name="workspace_center" pos="0 0 0" rgba="0.2 0.2 0.2 0.4"/>

      <body name="link1" pos="0 0 0">
        <joint name="shoulder" type="hinge" axis="0 0 1" range="-3.14 3.14" frictionloss="0.02"/>
        <geom fromto="0 0 0 0.18 0 0"/>

        <body name="link2" pos="0.18 0 0">
          <joint name="elbow" type="hinge" axis="0 0 1" range="-3.14 3.14" frictionloss="0.02"/>
          <geom fromto="0 0 0 0.16 0 0"/>
          <site name="ee_site" pos="0.16 0 0" rgba="0.1 0.75 0.3 1"/>
        </body>
      </body>
    </body>

    <body name="target" mocap="true" pos="0.22 0.12 0">
      <geom name="target_geom" type="sphere" size="0.02" rgba="0.95 0.25 0.2 0.9" contype="0" conaffinity="0"/>
      <site name="target_site" pos="0 0 0" rgba="0.95 0.25 0.2 0.4"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="shoulder_motor" joint="shoulder" gear="38"/>
    <motor name="elbow_motor" joint="elbow" gear="38"/>
  </actuator>

  <sensor>
    <jointpos name="shoulder_pos" joint="shoulder"/>
    <jointpos name="elbow_pos" joint="elbow"/>
    <jointvel name="shoulder_vel" joint="shoulder"/>
    <jointvel name="elbow_vel" joint="elbow"/>
    <framepos name="ee_pos" objtype="site" objname="ee_site"/>
  </sensor>
</mujoco>

